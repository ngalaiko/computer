#!/bin/sh
# Generate the VM's SSH host keys (needed for sshd to start; the client only
# ever sees exe.dev's gateway cert, so these are effectively internal).
set -eu
mkdir -p /run/sshd
[ -f /run/ssh_host_ed25519_key ] || ssh-keygen -q -t ed25519 -f /run/ssh_host_ed25519_key -N ""
[ -f /run/ssh_host_rsa_key ]     || ssh-keygen -q -t rsa -b 4096 -f /run/ssh_host_rsa_key -N ""
