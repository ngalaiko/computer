#!/bin/sh
# PID 1 entrypoint (the image's Cmd). exe.dev boots this OCI image with its own
# kernel and runs our Cmd as PID 1 — so we're the init. Like the reference
# exe.dev image (johnrichardrinehart/exe.dev-nixos), we mount the pseudo-
# filesystems the platform doesn't provide, THEN exec s6-overlay's supervisor
# (/init). Doing the mounts *here*, in the full-privilege PID-1 context before
# any service, is what makes them stick: the same mount from a supervised s6
# service did not fix sshd's PTY on the VM.
#
# Without /dev/pts, sshd fails with "PTY allocation request failed on channel 0".
set -u
export PATH=/command:/nix/var/nix/profiles/default/bin:/nix/var/nix/profiles/default/sbin:/bin:/usr/bin

mkdir -p /proc /dev/pts
mountpoint -q /proc    || mount -t proc   proc   /proc || true
mountpoint -q /dev/pts || mount -t devpts devpts /dev/pts -o gid=5,mode=620,ptmxmode=666 || true
[ -e /dev/ptmx ] || ln -s pts/ptmx /dev/ptmx || true

exec /init "$@"
